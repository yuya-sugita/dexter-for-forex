//@version=6
// ============================================================================
// Renaissance Fintokei — XAUUSD 15m  (v3: Limit-Order, High-WR Edition)
// ============================================================================
//
// v2 を Fintokei チャレンジ制約 (有限時間・ハード DD・バイナリ通過判定)
// に特化させた版。Prompt 1 (データ先行) に従い、自己資本前提の Prompt 2
// (51% × 高試行) を「DD 制約下では分散縮小が EV より優先」と読み替え、
// 高 WR × R:R 1:1 × 指値ブレケット の構成に再設計する。
//
// v2 → v3 主要変更:
//   - 時間足: 1h → 15m              (試行回数の確保 / 統計的収束)
//   - 発注:  成行                  → 指値エントリー + OCO ブレケット
//                                    (チャート張り付き不要、感情排除 = P4 強化)
//   - WR/RR: 51% × 高 RR           → 65-72% × 1:1                (DD 縮小)
//   - L3/L4: 個別エントリーゲート → サイズ係数 (P8 の発想を 1 トレードに)
//   - L1/L2/L5: 状態ゲート維持     (regime が許可した日のみ指値投入)
//   - Fintokei ガード:
//       * 日次 -2.5% で当日新規停止 (5% 制限の半分で停止 = 安全マージン)
//       * 総 DD: -5%/-7%/-9% で α=0.5/0.25/0.0  (P8 の機械的縮小)
//       * 日次最大 6 トレード        (リベンジ取引の構造的禁止)
//       * 金曜 21:00 UTC 全クローズ (週末ギャップ回避)
//       * 経済発表時刻ブラックアウト (US 12:30 / 14:00 UTC ± 30 min)
//
// 6 エージェント (CLAUDE.md 同列制) との対応:
//   L1 mathematician      — 分散比 (Hurst 相当) で MR 位相を同定 [GATE]
//   L2 physicist          — ATR 比 + 尾 σ で相分類 (NORMAL のみ可)  [GATE]
//   L3 astronomer         — z 持続性で SN 比評価                    [SIZE]
//   L4 speech-recognition — HMM 状態の Viterbi 安定性               [SIZE]
//   L5 cryptanalyst       — 時間帯/曜日の条件付き分布で高エッジ窓  [GATE]
//   L6 quant-analyst      — 上記を Fintokei 制約 + Kelly に翻訳     [EXEC]
//
// 11 プロンプト対応:
//   P1  データ先行   — Prompt 2 の解釈をデータ (DD 制約) に従って変える
//   P2  51% エッジ   — 自己資本前提の話。本ファイルは prop firm 用に変奏する
//   P3  6 エージェント — L1..L6 にそのまま対応
//   P4  上書き禁止   — 全ブレケット OCO で執行、裁量介入なし
//   P5  ナラティブ禁止 — 数値条件のみ。「なぜ」は書かない
//   P6  独立層 AND   — L1∧L2∧L5 が同時 ON の時のみ指値投入
//   P7  失敗もデータ — entry comment に層・α・DD 情報を残す
//   P8  縮小しろ     — DD 階層 α、日次サーキットブレーカ
//   P9  モノリシック — 全層が同一 OHLCV / 同一統計プリミティブを参照
//   P10 尖度 (堀)    — 5 層の結合条件 + Fintokei ガードで多次元
//   P11 美しさ        — 1 原理 (条件成立で OCO 投入) + 最小パラメータ
//
// ============================================================================

strategy(
     title                   = "Renaissance Fintokei XAUUSD 15m",
     shorttitle              = "RenFT15",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 0,
     pyramiding              = 0,
     calc_on_every_tick      = false,
     process_orders_on_close = true,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.002)

// ============================================================================
// Inputs — 層パラメータと Fintokei ガード閾値
// ============================================================================

// --- L1 Mathematician ---
mathLookback = input.int(100, "L1 Variance-Ratio Lookback", minval = 50, maxval = 300, group = "L1 Mathematician")
mathK        = input.int(5,   "L1 Variance-Ratio Lag k",    minval = 2,  maxval = 20,  group = "L1 Mathematician")
mathVRMax    = input.float(0.95, "L1 VR Upper Bound",       minval = 0.5, maxval = 1.2, step = 0.05, group = "L1 Mathematician")

// --- L2 Physicist ---
physLaminarLo  = input.float(0.5,  "L2 Laminar Lower",  minval = 0.1, maxval = 0.9, step = 0.05, group = "L2 Physicist")
physCriticalHi = input.float(1.6,  "L2 Critical Upper", minval = 1.1, maxval = 3.0, step = 0.1,  group = "L2 Physicist")
physTailSigma  = input.float(4.0,  "L2 Tail σ Max",     minval = 2.0, maxval = 6.0, step = 0.5,  group = "L2 Physicist")

// --- L3 Astronomer (size factor) ---
astroLookback     = input.int(5,    "L3 Persistence window",       minval = 3,   maxval = 20,  group = "L3 Astronomer")
astroPersistMin   = input.float(1.0, "L3 |z| persistence threshold", minval = 0.5, maxval = 2.0, step = 0.1, group = "L3 Astronomer")
astroFactorWeak   = input.float(0.5, "L3 Size factor (weak)",       minval = 0.0, maxval = 1.0, step = 0.1, group = "L3 Astronomer")

// --- L4 HMM (size factor) ---
hmmSlopePct       = input.float(0.003, "L4 Slope threshold",         minval = 0.001, maxval = 0.02, step = 0.001, group = "L4 Speech-Recognition")
hmmHold           = input.int(8,        "L4 State-hold bars",        minval = 2,     maxval = 30,   group = "L4 Speech-Recognition")
hmmFactorWeak     = input.float(0.5,    "L4 Size factor (transit.)", minval = 0.0,   maxval = 1.0,  step = 0.1, group = "L4 Speech-Recognition")

// --- L5 Cryptanalyst ---
cryptoStartH      = input.int(13,    "L5 Core session start (UTC)", minval = 0, maxval = 23, group = "L5 Cryptanalyst")
cryptoEndH        = input.int(20,    "L5 Core session end (UTC)",   minval = 0, maxval = 23, group = "L5 Cryptanalyst")
cryptoBlackoutData = input.bool(true, "L5 Blackout US data hours",  group = "L5 Cryptanalyst")

// --- L6 Order geometry (z-score levels) ---
zLookback   = input.int(20,   "L6 z lookback",   minval = 10, maxval = 100, group = "L6 Order Geometry")
zEntry      = input.float(2.5, "L6 z entry",     minval = 1.5, maxval = 4.0, step = 0.1, group = "L6 Order Geometry")
zTakeProfit = input.float(1.5, "L6 z take-profit", minval = 0.0, maxval = 2.5, step = 0.1, group = "L6 Order Geometry")
zStopLoss   = input.float(3.5, "L6 z stop-loss", minval = 2.0, maxval = 5.0, step = 0.1, group = "L6 Order Geometry")
limitMaxAge = input.int(8,    "L6 Limit max age (bars)", minval = 2, maxval = 30, group = "L6 Order Geometry")

// --- Fintokei guards ---
baseRiskPct      = input.float(0.5, "Base risk per trade %", minval = 0.1, maxval = 2.0, step = 0.1, group = "Fintokei Guards")
maxDailyDDpct    = input.float(2.5, "Daily DD circuit %",    minval = 1.0, maxval = 5.0, step = 0.5, group = "Fintokei Guards")
maxTradesPerDay  = input.int(6,     "Max trades / day",      minval = 1,   maxval = 20,  group = "Fintokei Guards")
ddTier1Pct       = input.float(5.0, "Total DD α=0.50 %",     minval = 2.0, maxval = 10.0, step = 0.5, group = "Fintokei Guards")
ddTier2Pct       = input.float(7.0, "Total DD α=0.25 %",     minval = 3.0, maxval = 12.0, step = 0.5, group = "Fintokei Guards")
ddTier3Pct       = input.float(9.0, "Total DD α=0.00 %",     minval = 5.0, maxval = 15.0, step = 0.5, group = "Fintokei Guards")
fridayCloseH     = input.int(21,    "Friday flat hour (UTC)", minval = 18, maxval = 23, group = "Fintokei Guards")

// ============================================================================
// Shared primitives — Prompt 9: 全層が同じ原始量を参照
// ============================================================================

ret1   = close - close[1]
ret5   = close - close[5]
atr14  = ta.atr(14)
atr100 = ta.sma(atr14, 100)
sma20  = ta.sma(close, zLookback)
std20  = ta.stdev(close, zLookback)
sma50  = ta.sma(close, 50)
hUtc   = hour(time, "UTC")
mUtc   = minute(time, "UTC")
dow    = dayofweek(time, "UTC")
zRaw   = std20 > 0 ? (close - sma20) / std20 : 0.0

// ============================================================================
// L1 — MATHEMATICIAN: variance ratio で平均回帰位相の同定 [GATE]
// ============================================================================
var1 = ta.variance(ret1, mathLookback)
varK = ta.variance(ret5, mathLookback)
vr   = var1 > 0 ? varK / (mathK * var1) : 1.0
l1_math_OK = vr < mathVRMax

// ============================================================================
// L2 — PHYSICIST: 相分類 (NORMAL のみエントリー可) [GATE]
// ============================================================================
atrRatio = atr100 > 0 ? atr14 / atr100 : 1.0
sdRet    = ta.stdev(ret1, 100)
maxAbs   = ta.highest(math.abs(ret1), 20)
tailSig  = sdRet > 0 ? maxAbs / sdRet : 0.0
l2_phys_OK = atrRatio >= physLaminarLo and atrRatio <= physCriticalHi and tailSig < physTailSigma

// ============================================================================
// L3 — ASTRONOMER: z 持続性 → サイズ係数 [SIZE]
// ============================================================================
// 過去 astroLookback バーの平均 |z| が閾値以上なら「観測信号が立っている」
// → サイズ 1.0。閾値未満ならノイズ寄り → サイズ astroFactorWeak。
absZ = math.abs(zRaw)
avgAbsZ = ta.sma(absZ, astroLookback)
l3_astro_factor = avgAbsZ >= astroPersistMin ? 1.0 : astroFactorWeak

// ============================================================================
// L4 — SPEECH-RECOGNITION: HMM 状態安定性 → サイズ係数 [SIZE]
// ============================================================================
sma50_20ago = sma50[20]
slopeFrac   = sma50_20ago > 0 ? (sma50 - sma50_20ago) / sma50_20ago : 0.0
state_now   = slopeFrac > hmmSlopePct ? 1 : slopeFrac < -hmmSlopePct ? -1 : 0

state_stable = true
for i = 1 to hmmHold
    if state_now != nz(state_now[i])
        state_stable := false

l4_hmm_factor = state_stable ? 1.0 : hmmFactorWeak

// ============================================================================
// L5 — CRYPTANALYST: 時間帯/曜日条件 + 経済発表ブラックアウト [GATE]
// ============================================================================
inCore       = hUtc >= cryptoStartH and hUtc < cryptoEndH
fridayLate   = dow == dayofweek.friday and hUtc >= 20
sundayOpen   = dow == dayofweek.sunday
// US データ発表時刻 (典型: 12:30 UTC = NFP/CPI, 14:00 UTC = FOMC/JOLTs)
// その時刻 ± 30 分をブラックアウト
near1230 = (hUtc == 12 and mUtc >= 0) or (hUtc == 13 and mUtc < 0)
near1400 = (hUtc == 13 and mUtc >= 30) or (hUtc == 14) or (hUtc == 15 and mUtc < 0)
dataBlackout = cryptoBlackoutData and (near1230 or near1400)

l5_crypto_OK = inCore and not fridayLate and not sundayOpen and not dataBlackout

// ============================================================================
// L6 — QUANT-ANALYST: 翻訳と執行
// ============================================================================
// 状態ゲート (L1∧L2∧L5) が成立した時のみ、L3×L4 のサイズ係数を反映した
// 指値ブレケット (OCO) を long/short 両側に投入する。
// 片側が約定したら反対側を即キャンセル。

state_OK = l1_math_OK and l2_phys_OK and l5_crypto_OK

// --- DD 制御 (Prompt 8 の機械的スカラー縮小) ---
var float peakEq = strategy.initial_capital
peakEq := math.max(peakEq, strategy.equity)
ddPct  = peakEq > 0 ? (peakEq - strategy.equity) / peakEq * 100.0 : 0.0

alpha_dd = ddPct >= ddTier3Pct ? 0.00 :
           ddPct >= ddTier2Pct ? 0.25 :
           ddPct >= ddTier1Pct ? 0.50 : 1.00

// --- 日次トラッキング (Fintokei daily DD 制限への対応) ---
var int   currentDay     = na
var float dayStartEq     = na
var int   dayTradeCount  = 0
var bool  dayHaltedFlag  = false

today = dayofyear(time, "UTC") + year(time, "UTC") * 1000
isNewDay = na(currentDay) or currentDay != today
if isNewDay
    currentDay := today
    dayStartEq := strategy.equity
    dayTradeCount := 0
    dayHaltedFlag := false

dailyPnLpct = (not na(dayStartEq) and dayStartEq > 0) ?
              (strategy.equity - dayStartEq) / dayStartEq * 100.0 : 0.0

if dailyPnLpct <= -maxDailyDDpct
    dayHaltedFlag := true

// --- 金曜クローズ ---
fridayHaltTime = dow == dayofweek.friday and hUtc >= fridayCloseH

// --- 投入許可 ---
canPlace = state_OK and alpha_dd > 0 and not dayHaltedFlag and not fridayHaltTime and (dayTradeCount < maxTradesPerDay) and (strategy.position_size == 0)

// --- z レベル → 価格 ---
longEntryPx  = sma20 - zEntry      * std20
longTpPx     = sma20 - zTakeProfit * std20
longStopPx   = sma20 - zStopLoss   * std20
shortEntryPx = sma20 + zEntry      * std20
shortTpPx    = sma20 + zTakeProfit * std20
shortStopPx  = sma20 + zStopLoss   * std20

// --- ストップ距離 (リスク逆算用) ---
stopDistAbs = (zStopLoss - zEntry) * std20  // |entry-stop| in price units

// --- サイズ係数とリスク% ---
sizeFactor = l3_astro_factor * l4_hmm_factor   // 0.25 / 0.5 / 1.0 のいずれか
riskPct    = baseRiskPct * alpha_dd * sizeFactor
riskAmount = strategy.equity * (riskPct / 100.0)
qtyUnits   = (stopDistAbs > 0 and riskAmount > 0) ? riskAmount / stopDistAbs : 0.0

// --- 指値ブレケット投入 (両側) ---
// ID は固定 ("L"/"S")。再呼び出しでオーダーを更新する仕様を活用し、
// state_OK の間は常に最新の z レベルに指値を追従させる。
if canPlace and qtyUnits > 0 and longEntryPx < close and shortEntryPx > close
    confTag = "α=" + str.tostring(alpha_dd, "#.##") + " sz=" + str.tostring(sizeFactor, "#.##") + " dd=" + str.tostring(ddPct, "#.#") + "%"
    strategy.entry("L", strategy.long,  qty = qtyUnits, limit = longEntryPx,  comment = "L " + confTag)
    strategy.exit ("L_x", from_entry = "L", limit = longTpPx,  stop = longStopPx)
    strategy.entry("S", strategy.short, qty = qtyUnits, limit = shortEntryPx, comment = "S " + confTag)
    strategy.exit ("S_x", from_entry = "S", limit = shortTpPx, stop = shortStopPx)

// --- 状態が崩れたら未約定指値をキャンセル ---
if (not canPlace) and strategy.position_size == 0
    strategy.cancel("L")
    strategy.cancel("S")

// --- 古い未約定指値の年齢管理 ---
// 直近 limitMaxAge バーの間に canPlace が連続していなければ、stale orders と見做して再構築させる
var int lastPlacedBar = na
if canPlace and qtyUnits > 0 and longEntryPx < close and shortEntryPx > close
    lastPlacedBar := bar_index
if not na(lastPlacedBar) and (bar_index - lastPlacedBar) > limitMaxAge and strategy.position_size == 0
    strategy.cancel("L")
    strategy.cancel("S")
    lastPlacedBar := na

// --- 約定検知 → 反対側キャンセル + 日次カウンタ ---
positionJustOpened = strategy.position_size != 0 and strategy.position_size[1] == 0
if positionJustOpened
    dayTradeCount := dayTradeCount + 1
    if strategy.position_size > 0
        strategy.cancel("S")
    else
        strategy.cancel("L")

// --- 金曜強制クローズ ---
if fridayHaltTime
    strategy.cancel("L")
    strategy.cancel("S")
    if strategy.position_size != 0
        strategy.close_all(comment = "friday-flat")

// --- 日次サーキットブレーカ発動時: 新規禁止 (既存ポジは bracket に任せる) ---
if dayHaltedFlag and strategy.position_size == 0
    strategy.cancel("L")
    strategy.cancel("S")

// ============================================================================
// Visualization — 取引ロジックには影響しない診断レイヤ
// ============================================================================

plot(sma20,        title = "SMA(20) mean",     color = color.new(color.aqua,    40))
plot(longEntryPx,  title = "z=-2.5 (L entry)", color = color.new(color.green,   30), linewidth = 1, style = plot.style_circles)
plot(longTpPx,     title = "z=-1.5 (L TP)",    color = color.new(color.green,   60), linewidth = 1)
plot(longStopPx,   title = "z=-3.5 (L stop)",  color = color.new(color.red,     60), linewidth = 1)
plot(shortEntryPx, title = "z=+2.5 (S entry)", color = color.new(color.red,     30), linewidth = 1, style = plot.style_circles)
plot(shortTpPx,    title = "z=+1.5 (S TP)",    color = color.new(color.red,     70), linewidth = 1)
plot(shortStopPx,  title = "z=+3.5 (S stop)",  color = color.new(color.green,   70), linewidth = 1)

bgcolor(not l1_math_OK   ? color.new(color.purple, 92) : na, title = "L1 Math OFF")
bgcolor(not l2_phys_OK   ? color.new(color.red,    92) : na, title = "L2 Phys OFF")
bgcolor(not l5_crypto_OK ? color.new(color.orange, 93) : na, title = "L5 Crypto OFF")
bgcolor(dayHaltedFlag    ? color.new(color.maroon, 85) : na, title = "Daily DD halt")
bgcolor(fridayHaltTime   ? color.new(color.gray,   85) : na, title = "Friday flat")

// 状態ダッシュボード
var table dash = table.new(position.top_right, 3, 9, border_width = 1)
if barstate.islast
    table.cell(dash, 0, 0, "Layer",     bgcolor = color.new(color.black, 20), text_color = color.white)
    table.cell(dash, 1, 0, "Reading",   bgcolor = color.new(color.black, 20), text_color = color.white)
    table.cell(dash, 2, 0, "Status",    bgcolor = color.new(color.black, 20), text_color = color.white)

    table.cell(dash, 0, 1, "L1 Math",   text_color = color.white)
    table.cell(dash, 1, 1, "VR=" + str.tostring(vr, "#.##"), text_color = color.white)
    table.cell(dash, 2, 1, l1_math_OK ? "GATE ✓" : "GATE ✗", text_color = l1_math_OK ? color.green : color.red)

    table.cell(dash, 0, 2, "L2 Phys",   text_color = color.white)
    table.cell(dash, 1, 2, "ar=" + str.tostring(atrRatio, "#.##") + " τ=" + str.tostring(tailSig, "#.#"), text_color = color.white)
    table.cell(dash, 2, 2, l2_phys_OK ? "GATE ✓" : "GATE ✗", text_color = l2_phys_OK ? color.green : color.red)

    table.cell(dash, 0, 3, "L3 Astro",  text_color = color.white)
    table.cell(dash, 1, 3, "<|z|>=" + str.tostring(avgAbsZ, "#.##"), text_color = color.white)
    table.cell(dash, 2, 3, "size×" + str.tostring(l3_astro_factor, "#.##"), text_color = color.white)

    table.cell(dash, 0, 4, "L4 HMM",    text_color = color.white)
    table.cell(dash, 1, 4, (state_now == 1 ? "UP" : state_now == -1 ? "DN" : "FL") + (state_stable ? "(s)" : "(t)"), text_color = color.white)
    table.cell(dash, 2, 4, "size×" + str.tostring(l4_hmm_factor, "#.##"), text_color = color.white)

    table.cell(dash, 0, 5, "L5 Crypto", text_color = color.white)
    table.cell(dash, 1, 5, "h=" + str.tostring(hUtc) + ":" + str.tostring(mUtc) + " dow=" + str.tostring(dow), text_color = color.white)
    table.cell(dash, 2, 5, l5_crypto_OK ? "GATE ✓" : "GATE ✗", text_color = l5_crypto_OK ? color.green : color.red)

    table.cell(dash, 0, 6, "Total DD",  bgcolor = color.new(color.yellow, 80), text_color = color.white)
    table.cell(dash, 1, 6, str.tostring(ddPct, "#.##") + "%", text_color = color.white)
    table.cell(dash, 2, 6, "α=" + str.tostring(alpha_dd, "#.##"), text_color = alpha_dd < 1 ? color.orange : color.green)

    table.cell(dash, 0, 7, "Daily PnL", bgcolor = color.new(color.yellow, 80), text_color = color.white)
    table.cell(dash, 1, 7, str.tostring(dailyPnLpct, "#.##") + "%", text_color = dayHaltedFlag ? color.red : color.white)
    table.cell(dash, 2, 7, dayHaltedFlag ? "HALT" : (str.tostring(dayTradeCount) + "/" + str.tostring(maxTradesPerDay)), text_color = dayHaltedFlag ? color.red : color.white)

    table.cell(dash, 0, 8, "Order",     bgcolor = color.new(color.blue, 70), text_color = color.white)
    table.cell(dash, 1, 8, "qty=" + str.tostring(qtyUnits, "#.###"), text_color = color.white)
    table.cell(dash, 2, 8, canPlace ? "ARMED" : "IDLE", text_color = canPlace ? color.green : color.gray)
