# LLM APIキー
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Ollama（ローカルLLM）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 持続的メモリの埋め込みは既存のモデルAPIキーを再利用します。
# 優先順位: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# メモリ専用の追加APIキーは不要です。

# Twelve Data APIキー（市場データ、テクニカル指標、経済カレンダー）
# 無料キーの取得: https://twelvedata.com/
TWELVE_DATA_API_KEY=your-twelve-data-api-key

# Web検索APIキー（Exa → Perplexity → Tavily の優先順位）
EXASEARCH_API_KEY=your-exa-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
TAVILY_API_KEY=your-tavily-api-key

# X/Twitter API（マーケットセンチメント調査用のx_searchツールを有効化）
X_BEARER_TOKEN=your-X-bearer-token

# LangSmith（トレーシング・評価）
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=sapiens
LANGSMITH_TRACING=false
